rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /actions/{action} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.creator;
      allow read: if request.auth != null;
    }

    match /tables/{tableid} {
      allow create: if request.auth != null;
    }
    match /tables/{tableid}/actions/{action} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
    }

    match /gamedef/{document=**} {
      allow read: if request.auth != null;
    }

    match /users/{document=**} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow write: if request.auth != null && request.auth.uid == resource.data.uid;
      allow read: if request.auth != null;
    }

    match /thingsPrompts/{prompt} {
      allow read: if request.auth != null;
    }

    match /thingsPositivePrompts/{prompt} {
      allow read: if request.auth != null;
    }

    match /thingsPromptDeck/state {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['currentIndex', 'seed', 'totalEntries', 'updatedAt'])
        && request.resource.data.currentIndex is int
        && request.resource.data.seed is int
        && request.resource.data.totalEntries is int;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['currentIndex', 'seed', 'totalEntries', 'updatedAt'])
        && request.resource.data.currentIndex is int
        && request.resource.data.seed is int
        && request.resource.data.totalEntries is int;
    }

    match /{name=**}/requests/{action} {
      allow read: if request.auth.uid == resource.data.target;
    }
    match /from/{uid}/to/{uid2}/requests/{action} {
      allow write: if uid == request.auth.uid
        && request.resource.data.creator == request.auth.uid
        && request.resource.data.target == uid2;
    }
  }
}
