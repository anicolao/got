{
  "name": "got",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 5174 --strictPort",
    "build": "vite build",
    "preview": "vite preview --port 4174 --strictPort",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "test": "npm run check && npm run test:unit && npm run test:e2e",
    "seed:prompts": "node scripts/seed-prompt-deck.mjs"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "firebase": "^12.6.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@playwright/test": "^1.57.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.49.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/node": "^25.0.6",
    "@types/qrcode": "^1.5.6",
    "firebase-admin": "^14.1.0",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.15"
  }
}
